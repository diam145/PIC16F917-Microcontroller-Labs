                      01253         LIST
                      00002 
2007   30E4           00003         __CONFIG    _CP_OFF & _CPD_OFF & _BOD_OFF & _PWRTE_ON & _WDT_OFF & _INTRC_OSC_NOCLKOUT & _MCLRE_
                            ON & _FCMEN_OFF & _IESO_OFF
                      00004 
                      00005         errorlevel -302         ; supress "register not in bank0, check page bits" message
                      00006 
                      00007 ; Pin Declarations (Mappings provided by lab)
                      00008 #define SW2     PORTA, 2    ; SensorLOW (RA2)
                      00009 #define SW3     PORTA, 3    ; SensorHIGH (RA3)
                      00010 #define LED1    PORTD, 5    ; Reflects SensorLOW status (D5)
                      00011 #define LED2    PORTD, 6    ; Reflects SensorHIGH status (D6)
                      00012 #define LED7    PORTD, 7    ; Pump Status (D7)
                      00013         
                      00014 ;--- Student Complete Section above
                      00015 ; Variable Declarations
                      00016         cblock  0x20
  00000020            00017                 Temp
                      00018         endc
