                      00017 
                      00018 ;************************************************************************************
                      00019   org 0x00
0000   2???           00020         goto    Initialize
                      00021 
                      00022   org 0x05
                      00023 
                      00024 ;************************************************************************************
                      00025 ; Initialize - Initialize comparators, internal oscillator, I/O pins, 
                      00026 ;       analog pins, variables  
                      00027 ;
                      00028 ;************************************************************************************
0005                  00029 Initialize
                      00030     ; 1. Set Clock Speed (Bank 1)
0005   1683 1303      00031     banksel OSCCON
0007   3070           00032     movlw   b'01110000'     ; Set to 8MHz (as per your previous code)
0008   008F           00033     movwf   OSCCON
                      00034 
                      00035     ; 2. Disable Comparators (Bank 0)
0009   1683 1303      00036     banksel CMCON0
000B   3007           00037     movlw   0x07            ; 0x07 turns off comparators to allow digital I/O
000C   009C           00038     movwf   CMCON0
                      00039 
                      00040     ; 3. Disable Analog (Bank 3)
                      00041     ; Note: banksel is vital here because ANSEL is in Bank 3!
000D   1683 1303      00042     banksel ANSEL       
000F   0191           00043     clrf    ANSEL       
                      00044 
                      00045     ; 4. Configure I/O Direction (Bank 1)
0010   1683 1303      00046     banksel TRISA
0012   300C           00047     movlw   b'00001100'     ; RA2 and RA3 as inputs (1)
0013   0085           00048     movwf   TRISA
                      00049     
0014   1683 1303      00050     banksel TRISD
0016   0188           00051     clrf    TRISD           ; Set Port D as outputs (0) for LEDs
                      00052 
                      00053     ; 5. Configure Timer0 (Bank 1)
0017   1683 1303      00054     banksel OPTION_REG
0019   3086           00055     movlw   b'10000110'     ; Pull-ups disabled, TMR0 Prescaler 1:128
001A   0081           00056     movwf   OPTION_REG
                      00057 
                      00058     ; 6. Final Reset and Enter Main (Bank 0)
001B   1283 1303      00059     banksel PORTA
001D   0185           00060     clrf    PORTA
001E   0188           00061     clrf    PORTD
001F   2???           00062     goto    Main
                      00063 
                      00064 ;************************************************************************************
                      00065 ; Main Control Loop
                      00066 ;************************************************************************************
0020                  00067 Main
MPASM 5.64                           WLC.ASM   2-2-2026  19:14:50         PAGE  3


LOC  OBJECT CODE     LINE SOURCE TEXT
  VALUE

0020   1283           00068     bcf     STATUS, RP0     ; Ensure we are in Bank 0
                      00069     
                      00070     ; --- Step 1: Pump Logic (Hysteresis) ---
                      00071     ; If Sensor High (LED2) is ON (1), turn Pump (LED7) OFF
0021   1B08           00072     btfsc   LED2            ; Is LED2 high?
0022   1388           00073     bcf     LED7            ; Yes, Tank is Full -> Pump OFF
                      00074     
                      00075     ; If Sensor Low (LED1) is OFF (0), turn Pump (LED7) ON
0023   1E88           00076     btfss   LED1            ; Is LED1 low?
0024   1788           00077     bsf     LED7            ; Yes, Tank is Empty -> Pump ON
                      00078 
                      00079     ; --- Step 2: Poll Switches ---
0025   1D05           00080     btfss   SW2             ; Is SW2 pressed (0)?
0026   2???           00081     goto    SENSOR_LOW      ; Yes, go update LED1
                      00082     
0027   1D85           00083     btfss   SW3             ; Is SW3 pressed (0)?
0028   2???           00084     goto    SENSOR_HIGH     ; Yes, go update LED2
                      00085     
0029   2???           00086     goto    Main            ; No buttons pressed? Loop back to start
                      00087 
002A                  00088 SENSOR_LOW
002A   3020           00089     movlw   b'00100000'     ; Mask for LED1 (RD5)
002B   0688           00090     xorwf   PORTD, F        ; Toggle LED1
002C   2???           00091     goto    DebounceStateSW2 ; Wait for release, then goto Main
                      00092 
002D                  00093 SENSOR_HIGH
002D   3040           00094     movlw   b'01000000'     ; Mask for LED2 (RD6)
002E   0688           00095     xorwf   PORTD, F        ; Toggle LED2
002F   2???           00096     goto    DebounceStateSW3 ; Wait for release, then goto Main
                      00097 
                      00098 
                      00099 ;************************************************************************************
                      00100 ; Debounce Routines
                      00101 ;************************************************************************************
0030                  00102 DebounceStateSW2                                ; Wait here until SW2 is released
0030   1D05           00103         btfss   SW2
0031   2???           00104         goto    DebounceStateSW2
0032   0181           00105         clrf    TMR0                    ; Once released clear TMR0 and the TMR0 interrupt flag
0033   110B           00106         bcf     INTCON,T0IF             ;  in preparation to time 16ms
                      00107 
0034                  00108 DebounceState2SW2                               ; State2 makes sure than SW2 is unpressed for 16ms befor
                            e
0034   1D05           00109         btfss   SW2                                     ;  returning to look for the next time SW2 is pr
                            essed
0035   2???           00110         goto    DebounceStateSW2        ; If SW2 is pressed again in this state then return to State1
0036   1D0B           00111         btfss   INTCON,T0IF             ; Else, continue to count down 16ms
0037   2???           00112         goto    DebounceState2SW2       ; Time = TMR0_max * TMR0 prescaler * (1/(Fosc/4)) = 256*128*0.5E
                            -6 = 16.4ms
0038   2???           00113         goto    Main
                      00114 
0039                  00115 DebounceStateSW3                                ; Wait here until SW2 is released
0039   1D85           00116         btfss   SW3
003A   2???           00117         goto    DebounceStateSW3
MPASM 5.64                           WLC.ASM   2-2-2026  19:14:50         PAGE  4


