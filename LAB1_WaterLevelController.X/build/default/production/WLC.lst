003B   0181           00118         clrf    TMR0                    ; Once released clear TMR0 and the TMR0 interrupt flag
003C   110B           00119         bcf     INTCON,T0IF             ;  in preparation to time 16ms
                      00120 
003D                  00121 DebounceState2SW3                                       ; State2 makes sure than SW2 is unpressed for 16
                            ms before
003D   1D85           00122         btfss   SW3                                     ;  returning to look for the next time SW2 is pr
                            essed
003E   2???           00123         goto    DebounceStateSW3        ; If SW2 is pressed again in this state then return to State1
003F   1D0B           00124         btfss   INTCON,T0IF             ; Else, continue to count down 16ms
0040   2???           00125         goto    DebounceState2SW3               ; Time = TMR0_max * TMR0 prescaler * (1/(Fosc/4)) = 256*
                            128*0.5E-6 = 16.4ms
0041   2???           00126         goto    Main
