                      00011 ;                                                                     
                      00012 ;    Notes:                                                           
                      00013 ;     This project shows the status of a Water Level Controller
                      00014 ;                                                        
                      00015 ;************************************************************************************
                      00016         #include        <WLC.inc>                       ; this file includes variable definitions and pi
                            n assignments   
                      00001 #include <p16f917.inc>
