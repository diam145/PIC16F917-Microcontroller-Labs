                      00001 ;**********************************************************************
                      00002 ; ELG4159 Lab 4: Analog Signal Generation
                      00003 ; Group Number: 8
                      00004 ; Student Name: Diallo Mamadou Mountaga (#300266156)
                      00005 ;
                      00006 ; Parameters (Group 8):
                      00007 ;   - Oscillator: 8 MHz
                      00008 ;   - Analog Input: POT1 on AN0 (RA0)
                      00009 ;   - PWM Output: CCP2 on RD2
                      00010 ;**********************************************************************
                      00011 
                      00012     #include <p16f917.inc>
                      00001         LIST
                      00002 
                      00003 ;==========================================================================
                      00004 ; Build date : Oct 21 2015
                      00005 ;  MPASM PIC16F917 processor include
                      00006 ; 
                      00007 ;  (c) Copyright 1999-2015 Microchip Technology, All rights reserved
                      00008 ;==========================================================================
                      00009 
                      01253         LIST
                      00013  
2007   30E4           00014     __CONFIG _CP_OFF & _CPD_OFF & _BOD_OFF & _PWRTE_ON & _WDT_OFF & _INTRC_OSC_NOCLKOUT & _MCLRE_ON & _F
                            CMEN_OFF & _IESO_OFF
                      00015     errorlevel -302
                      00016 
                      00017 ;-------------------------------------------------------------------------------
                      00018 ; RAM VARIABLES
                      00019 ;-------------------------------------------------------------------------------
                      00020     CBLOCK 0x20
  00000020            00021         DUTY_LSB_HOLD       ; Temporary storage for calculating the lower 2 bits of duty cycle
                      00022     ENDC
                      00023 
                      00024 ;-------------------------------------------------------------------------------
                      00025 ; RESET VECTOR
                      00026 ;-------------------------------------------------------------------------------
                      00027     ORG     0x00
0000   2???           00028     GOTO    Setup_Hardware
                      00029 
                      00030 ;-------------------------------------------------------------------------------
                      00031 ; PERIPHERAL INITIALIZATION
                      00032 ;-------------------------------------------------------------------------------
                      00033     ORG     0x05
0005                  00034 Setup_Hardware
                      00035     ; --- 1. Oscillator Configuration (8 MHz) ---
0005   1683 1303      00036     BANKSEL OSCCON
0007   3071           00037     MOVLW   0x71            ; IRCF=111 (8 MHz), SCS=1 (Internal Oscillator Block)
0008   008F           00038     MOVWF   OSCCON
                      00039 
                      00040     ; --- Disable unused modules to prevent pin interference ---
0009   1283 1703      00041     BANKSEL LCDCON
000B   0187           00042     CLRF    LCDCON          ; Turn off LCD controller to free up pins
MPASM 5.64                          MAIN.ASM   3-30-2026  20:12:05         PAGE  2


LOC  OBJECT CODE     LINE SOURCE TEXT
  VALUE

                      00043 
000C   1683 1303      00044     BANKSEL CMCON0
000E   3007           00045     MOVLW   0x07            ; Turn off Analog Comparators (CRITICAL: RA0 is shared with C1IN+)
000F   009C           00046     MOVWF   CMCON0
                      00047 
                      00048     ; --- 2. I/O & Analog Configuration ---
                      00049     ; Group 8 -> Potentiometer Input on AN0 (RA0)
0010   1683 1303      00050     BANKSEL TRISA
0012   1405           00051     BSF     TRISA, 0        ; Configure RA0 as an input
                      00052 
                      00053     ; PWM Output on CCP2 (RD2)
0013   1683 1303      00054     BANKSEL TRISD
0015   1108           00055     BCF     TRISD, 2        ; Configure RD2 as an output
                      00056 
                      00057     ; Enable analog function strictly on AN0
0016   1683 1303      00058     BANKSEL ANSEL
0018   3001           00059     MOVLW   B'00000001'     ; Set bit 0 to 1 (enables AN0)
0019   0091           00060     MOVWF   ANSEL
                      00061 
                      00062     ; --- 3. PWM Configuration ---
001A   1683 1303      00063     BANKSEL PR2
001C   30FF           00064     MOVLW   D'255'          ; Set max period (0xFF) to achieve exactly 10-bit resolution
001D   0092           00065     MOVWF   PR2
                      00066 
001E   1283 1303      00067     BANKSEL T2CON
0020   3004           00068     MOVLW   B'00000100'     ; Turn Timer2 ON with a 1:1 Prescaler
0021   0092           00069     MOVWF   T2CON
                      00070 
0022   1283 1303      00071     BANKSEL CCP2CON
0024   300C           00072     MOVLW   B'00001100'     ; Enable PWM mode on CCP2 module
0025   009D           00073     MOVWF   CCP2CON
                      00074 
                      00075     ; --- 4. ADC Configuration ---
0026   1683 1303      00076     BANKSEL ADCON1
0028   3050           00077     MOVLW   B'01010000'     ; Set Vref=VSS/VDD, Conversion Clock=Fosc/16, Left Justified
0029   009F           00078     MOVWF   ADCON1
                      00079 
002A   1283 1303      00080     BANKSEL ADCON0
002C   3001           00081     MOVLW   B'00000001'     ; Select Channel 0 (AN0), Turn ADC ON (ADON=1)
002D   009F           00082     MOVWF   ADCON0
                      00083 
                      00084 ;-------------------------------------------------------------------------------
                      00085 ; MAIN LOOP
                      00086 ;-------------------------------------------------------------------------------
002E                  00087 Main_Loop
                      00088     ; --- 5. ADC Acquisition ---
002E   1283 1303      00089     BANKSEL ADCON0
0030   149F           00090     BSF     ADCON0, GO      ; Trigger the ADC conversion
                      00091 
0031                  00092 Wait_For_ADC
0031   189F           00093     BTFSC   ADCON0, GO      ; Wait here until the GO bit drops back to 0 (conversion complete)
0032   2???           00094     GOTO    Wait_For_ADC
                      00095 
MPASM 5.64                          MAIN.ASM   3-30-2026  20:12:05         PAGE  3


LOC  OBJECT CODE     LINE SOURCE TEXT
  VALUE

                      00096     ; --- 6. Potentiometer Response Logic ---
                      00097     ; Check if ADRESH is perfectly zero to implement a "hard stop". 
                      00098     ; This prevents the motor from whining or flickering at very low potentiometer settings.
0033   1283 1303      00099     BANKSEL ADRESH
0035   081E           00100     MOVF    ADRESH, W
0036   1D03           00101     BTFSS   STATUS, Z
0037   2???           00102     GOTO    Apply_Duty_Cycle ; If W is not zero, proceed to update the PWM
                      00103 
                      00104     ; Execute Hard Stop: Force duty cycle to absolute zero
0038   1283 1303      00105     BANKSEL CCPR2L
003A   019B           00106     CLRF    CCPR2L
003B   1283 1303      00107     BANKSEL CCP2CON
003D   300C           00108     MOVLW   B'00001100'     ; Reset CCP2CON to just the basic PWM enable bits
003E   009D           00109     MOVWF   CCP2CON
003F   2???           00110     GOTO    Main_Loop       ; Return to the start of the loop
                      00111 
0040                  00112 Apply_Duty_Cycle
                      00113     ; Transfer the 8 Most Significant Bits (MSB) directly into the PWM holding register
0040   1283 1303      00114     BANKSEL ADRESH
0042   081E           00115     MOVF    ADRESH, W
0043   1283 1303      00116     BANKSEL CCPR2L
0045   009B           00117     MOVWF   CCPR2L          ; Update the high 8 bits of the Duty Cycle
                      00118 
                      00119     ; Extract and transfer the 2 Least Significant Bits (LSB) to CCP2CON<5:4>
0046   1683 1303      00120     BANKSEL ADRESL
0048   081E           00121     MOVF    ADRESL, W
0049   39C0           00122     ANDLW   B'11000000'     ; Apply mask to isolate the top 2 bits of ADRESL
                      00123     
004A   1283 1303      00124     BANKSEL DUTY_LSB_HOLD   ; Ensure we are securely in Bank 0 before storing the temp variable
004C   00A0           00125     MOVWF   DUTY_LSB_HOLD
                      00126 
                      00127     ; Bitwise shift right twice to align the data into positions 5 and 4
004D   1003           00128     BCF     STATUS, C       ; Clear carry bit to avoid dragging garbage data
004E   0CA0           00129     RRF     DUTY_LSB_HOLD, F
004F   1003           00130     BCF     STATUS, C
0050   0C20           00131     RRF     DUTY_LSB_HOLD, W ; Final shifted result sits in the Working register (B'00xx0000')
                      00132     
                      00133     ; Merge the new LSBs without overwriting the crucial PWM Mode bits in CCP2CON
0051   3930           00134     ANDLW   B'00110000'     ; Safety mask: ensure only bits 5 and 4 contain data
0052   380C           00135     IORLW   B'00001100'     ; OR the data with the basic PWM mode bits (11xx)
0053   1283 1303      00136     BANKSEL CCP2CON
0055   009D           00137     MOVWF   CCP2CON         ; Write the final, perfect 10-bit configuration to the control register
                      00138 
0056   2???           00139     GOTO    Main_Loop       ; Infinite loop
                      00140 
30E4                  00141     END                     ; End of program
