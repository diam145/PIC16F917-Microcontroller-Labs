                      00001 ;************************************************************************************
                      00002 ; Group AO1 - 8
                      00003 ; Student: Mamadou Mountaga Diallo (#300266156)
                      00004 ; Lab 3 - Continuous Polling & XOR Toggle Version (4 MSBs)
                      00005 ; 
                      00006 ; A = n modulo 8 = 8 mod 8 = 0 --> AN0(RA0)
                      00007 ; B = (n+1) modulo 8 = 9 mod 8 = 1 --> AN1(RA1)
                      00008 ; T = 1 second
                      00009 ;************************************************************************************
                      00010 
                      00011     #include <p16f917.inc>
                      00001         LIST
                      00002 
                      00003 ;==========================================================================
                      00004 ; Build date : Oct 21 2015
                      00005 ;  MPASM PIC16F917 processor include
                      00006 ; 
                      00007 ;  (c) Copyright 1999-2015 Microchip Technology, All rights reserved
                      00008 ;==========================================================================
                      00009 
                      01253         LIST
2007   30E4           00012     __CONFIG _CP_OFF & _CPD_OFF & _BOD_OFF & _PWRTE_ON & _WDT_OFF & _INTRC_OSC_NOCLKOUT & _MCLRE_ON & _F
                            CMEN_OFF & _IESO_OFF
                      00013     errorlevel -302
                      00014 
                      00015 ; Vars to store the result
  000000A0            00016 RESULTH EQU 0xA0
  000000A1            00017 RESULTL EQU 0xA1
                      00018     
                      00019     ORG 0x00
0000   2???           00020     GOTO Initialize
                      00021     ORG 0x05
                      00022     
0005                  00023 Initialize
0005   1303           00024     BCF     STATUS, RP1     ; Bank 1
0006   1683           00025     BSF     STATUS, RP0
                      00026     
                      00027     ; Turn off comparators
0007   3007           00028     MOVLW   0x07
0008   009C           00029     MOVWF   CMCON0
                      00030     
                      00031     ; Ocillator frequency
0009   3000           00032     MOVLW   0x00            ; 31kHz
000A   008F           00033     MOVWF   OSCCON
                      00034     
                      00035     ; Prescaler (1:32 assigned to TMR0)
000B   3084           00036     MOVLW   B'10000100'     ; 0x84
000C   0081           00037     MOVWF   OPTION_REG
                      00038     
                      00039     ; Config Input pins (RA0 and RA1)
000D   1405           00040     BSF     TRISA, RA0
000E   1485           00041     BSF     TRISA, RA1
                      00042     
MPASM 5.64                          MAIN.ASM   3-23-2026  19:47:34         PAGE  2


LOC  OBJECT CODE     LINE SOURCE TEXT
  VALUE

                      00043     ; Config Analog pins (AN0 and AN1)
000F   1411           00044     BSF     ANSEL, AN0
0010   1491           00045     BSF     ANSEL, AN1
                      00046     
                      00047     ; Config Outputs
0011   0188           00048     CLRF    TRISD           ; Output (LEDs 4-7 on PORTD)
0012   1006           00049     BCF     TRISB, 0        ; Output (LED0 on RB0)
                      00050     
                      00051     ; Turn ON the ADC and its Justification
0013   3000           00052     MOVLW   B'00000000'     ; Left Justified, Fosc/2
0014   009F           00053     MOVWF   ADCON1
                      00054     
                      00055     ; Back to Bank 0
0015   1283           00056     BCF     STATUS, RP0
                      00057     
                      00058     ; Set Initial State
0016   1406           00059     BSF     PORTB, 0        ; Start with LED0 ON (POT1)
0017   3001           00060     MOVLW   B'00000001'     ; Start with AN0, ADON=1
0018   009F           00061     MOVWF   ADCON0
                      00062     
0019   2???           00063     CALL    SampleTime      ; Initial charge delay
                      00064     
                      00065 ;**********************************************************************
                      00066 ; Main Program Loop
                      00067 ;**********************************************************************
001A                  00068 Main
001A   149F           00069     BSF     ADCON0, GO      ; Start first conversion
001B   2???           00070     CALL    ResetTimer      ; Start the 1-second window
001C   2???           00071     CALL    ConversionLoop  ; Sample & Display continuously for 1s
001D   2???           00072     CALL    Toggle          ; Switch POTs and toggle LED0
001E   2???           00073     GOTO    Main
                      00074 
                      00075 ;**********************************************************************
                      00076 ; ConversionLoop (Continuously polls until 1 second is up)
                      00077 ;**********************************************************************
001F                  00078 ConversionLoop
001F   189F           00079     BTFSC   ADCON0, GO      ; Wait for ADC to finish
0020   2???           00080     GOTO    ConversionLoop
                      00081     
                      00082     ; --- Save Results ---
0021   081E           00083     MOVF    ADRESH, W       ; Read High bits (Bank 0)
0022   1683           00084     BSF     STATUS, RP0     ; Bank 1
0023   00A0           00085     MOVWF   RESULTH
0024   081E           00086     MOVF    ADRESL, W       ; Read Low bits (Bank 1)
0025   00A1           00087     MOVWF   RESULTL
                      00088     
0026   2???           00089     CALL    DISPLAY_LEDS    ; Update the LEDs instantly
                      00090     
                      00091     ; --- Check Timer & Loop ---
0027   1283           00092     BCF     STATUS, RP0     ; Bank 0 for INTCON and ADCON0
0028   149F           00093     BSF     ADCON0, GO      ; Start next conversion immediately
0029   1D0B           00094     BTFSS   INTCON, T0IF    ; Has 1 second passed?
002A   2???           00095     GOTO    ConversionLoop  ; No? Keep sampling!
MPASM 5.64                          MAIN.ASM   3-23-2026  19:47:34         PAGE  3


LOC  OBJECT CODE     LINE SOURCE TEXT
  VALUE

002B   0008           00096     RETURN                  ; Yes? Return to Main to toggle channels
                      00097 
                      00098 ;**********************************************************************
                      00099 ; Toggle (Switches between AN0/AN1 and flips LED0)
                      00100 ;**********************************************************************
002C                  00101 Toggle
002C   1283           00102     BCF     STATUS, RP0     ; Bank 0
                      00103     
                      00104     ; Toggle LED0 on RB0
002D   3001           00105     MOVLW   B'00000001'
002E   0686           00106     XORWF   PORTB, F
                      00107     
                      00108     ; Toggle between AN0 (0000 0001) and AN1 (0000 0101)
002F   3004           00109     MOVLW   B'00000100'     ; Mask to flip bit 2 (CHS0)
0030   069F           00110     XORWF   ADCON0, F
                      00111     
0031   2???           00112     CALL    SampleTime      ; Let new channel voltage settle
0032   0008           00113     RETURN
                      00114 
                      00115 ;**********************************************************************
                      00116 ; ResetTimer (Clears flag and presets TMR0 for ~1 second)
                      00117 ;**********************************************************************
0033                  00118 ResetTimer
0033   1283           00119     BCF     STATUS, RP0     ; Bank 0
0034   110B           00120     BCF     INTCON, T0IF    ; Clear flag
0035   300E           00121     MOVLW   D'14'           ; 1-second math for 31kHz & 1:32 prescaler
0036   0081           00122     MOVWF   TMR0
0037   0008           00123     RETURN
                      00124 
                      00125 ;**********************************************************************
                      00126 ; SampleTime (Acquisition Delay)
                      00127 ;**********************************************************************
0038                  00128 SampleTime
0038   0000           00129     NOP
0039   0000           00130     NOP
003A   0008           00131     RETURN
                      00132 
                      00133 ;**********************************************************************
                      00134 ; DISPLAY_LEDS (Maps 4 MSBs to RD4-RD7 safely)
                      00135 ;**********************************************************************
003B                  00136 DISPLAY_LEDS
003B   1283           00137     BCF     STATUS, RP0     ; Ensure Bank 0 to write to PORTD
003C   0188           00138     CLRF    PORTD           ; Clear LEDs before updating
                      00139     
003D   1683           00140     BSF     STATUS, RP0     ; Switch to Bank 1 to read variables
                      00141     
                      00142     ; Check 4th MSB (Left-Justified bit 6 is RESULTH, bit 4) -> LED 7 (RD7)
003E   1A20           00143     BTFSC   RESULTH, 4
003F   2???           00144     GOTO    Set_LED7
0040                  00145 Next_Bit1
                      00146     ; Check 3rd MSB (Left-Justified bit 7 is RESULTH, bit 5) -> LED 6 (RD6)
0040   1AA0           00147     BTFSC   RESULTH, 5
0041   2???           00148     GOTO    Set_LED6
MPASM 5.64                          MAIN.ASM   3-23-2026  19:47:34         PAGE  4


LOC  OBJECT CODE     LINE SOURCE TEXT
  VALUE

0042                  00149 Next_Bit2
                      00150     ; Check 2nd MSB (Left-Justified bit 8 is RESULTH, bit 6) -> LED 5 (RD5)
0042   1B20           00151     BTFSC   RESULTH, 6
0043   2???           00152     GOTO    Set_LED5
0044                  00153 Next_Bit3
                      00154     ; Check 1st MSB (Left-Justified bit 9 is RESULTH, bit 7) -> LED 4 (RD4)
0044   1BA0           00155     BTFSC   RESULTH, 7
0045   2???           00156     GOTO    Set_LED4
                      00157     
0046   1283           00158     BCF     STATUS, RP0     ; Return to Bank 0 when done
0047   0008           00159     RETURN
                      00160 
0048                  00161 Set_LED7
0048   1283           00162     BCF     STATUS, RP0
0049   1788           00163     BSF     PORTD, 7
004A   1683           00164     BSF     STATUS, RP0
004B   2???           00165     GOTO    Next_Bit1
                      00166 
004C                  00167 Set_LED6
004C   1283           00168     BCF     STATUS, RP0
004D   1708           00169     BSF     PORTD, 6
004E   1683           00170     BSF     STATUS, RP0
004F   2???           00171     GOTO    Next_Bit2
                      00172 
0050                  00173 Set_LED5
0050   1283           00174     BCF     STATUS, RP0
0051   1688           00175     BSF     PORTD, 5
0052   1683           00176     BSF     STATUS, RP0
0053   2???           00177     GOTO    Next_Bit3
                      00178 
0054                  00179 Set_LED4
0054   1283           00180     BCF     STATUS, RP0
0055   1608           00181     BSF     PORTD, 4
0056   0008           00182     RETURN
                      00183 
30E4                  00184     END
